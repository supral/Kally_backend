# Server (localhost; use HOST=0.0.0.0 for production/Docker)
PORT=5000
HOST=localhost

# MongoDB (local: mongodb://127.0.0.1:27017/mbm | Atlas: mongodb+srv://user:pass@cluster.mongodb.net/mbm)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/mbm

# JWT (use a strong secret in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES=7d

# Production: frontend URL for CORS (e.g. https://your-app.com)
# FRONTEND_URL=https://your-app.com

# Admin seeder (optional - run: npm run seed)
# ADMIN_NAME=Admin
# ADMIN_EMAIL=admin@lishnutech.com
# ADMIN_PASSWORD=admin123
